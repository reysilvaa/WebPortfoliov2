{
	"name": "portofolio",
	"version": "0.0.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx src/lib/server/db/seed.ts",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@chromatic-com/storybook": "^5.0.1",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^9.39.4",
		"@inlang/paraglide-js": "^2.13.2",
		"@libsql/client": "^0.17.0",
		"@storybook/addon-a11y": "^10.2.19",
		"@storybook/addon-docs": "^10.2.19",
		"@storybook/addon-svelte-csf": "^5.0.11",
		"@storybook/addon-vitest": "^10.2.19",
		"@storybook/svelte": "^10.2.19",
		"@storybook/sveltekit": "^10.2.19",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^24.12.0",
		"@vitest/coverage-v8": "4.0.18",
		"better-auth": "~1.4.21",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.4.6",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.61.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"storybook": "^10.4.6",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.61.1",
		"vite": "^7.3.5",
		"vitest": "^4.1.9"
	},
	"keywords": [
		"svelte"
	],
	"dependencies": {
		"@vitest/browser-playwright": "^4.0.18"
	}
}
